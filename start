#!/usr/bin/env bash
#
# start — the whole product surface.
#
# The user pastes one line into their agent session:
#
#   git clone https://github.com/Humalike/humalike-audit-cli ~/.humalike/audit-cli 2>/dev/null; bash ~/.humalike/audit-cli/start
#
# The agent runs it and reads this script's stdout. That output is the only
# context the agent gets — no file it is told to open, no docs it might skip.
# So everything it needs to finish the job is printed here, in the order it
# needs it, short enough that it actually follows it. Treat this output as a
# prompt, because that is what it is.
#
# Login is split rather than blocking. Polling in the foreground would deadlock
# the agent-mediated flow: the shell call would not return until the human
# approved, so the agent could not relay the link to the human it is waiting
# on. Instead `--begin` prints the link and exits, and `--wait-login` picks the
# same session back up. One poller, no orphaned background process for a
# sandbox to reap, and the human always has the link before anything blocks.

set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY_BIN="python3"
MIN_PY="3.9"

# Show paths as ~/... so they match the canonical install location and stay
# copy-pasteable, without lying about where this checkout actually is.
HOME_DIR="${HOME:-}"
if [ -n "$HOME_DIR" ] && [ "${ROOT#"$HOME_DIR"/}" != "$ROOT" ]; then
  SHOW_ROOT="~/${ROOT#"$HOME_DIR"/}"
else
  SHOW_ROOT="$ROOT"
fi

LOGIN="$SHOW_ROOT/bin/humalike_login.py"
AUDIT="$SHOW_ROOT/bin/humalike_audit.py"
RULE="  ══════════════════════════════════════════════════════════════════════"

die() {
  printf '\n  Cannot start: %s\n\n' "$1" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage: bash $SHOW_ROOT/start [--status|--wait-login|--help]

Sets up the Humalike social audit for the agent running it: updates the
checkout, checks prerequisites, signs in if needed, and prints the playbook
the agent should follow.

  (no flags)     update, ensure a working key, print the playbook
  --status       print readiness only; exit 0 if ready, 1 if not
  --wait-login   block until the pending sign-in is approved, then save the key
  --help         this message
EOF
}

# --- prerequisites --------------------------------------------------------
# One plain actionable line per failure. An agent relays these to the human.

check_prereqs() {
  command -v "$PY_BIN" >/dev/null 2>&1 ||
    die "python3 is not installed. Install Python $MIN_PY or newer, then run this again."

  "$PY_BIN" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 9) else 1)' 2>/dev/null ||
    die "python3 is older than $MIN_PY. Install Python $MIN_PY or newer, then run this again."
}

# --- self-update ----------------------------------------------------------
# Best effort by design. A stale checkout still audits transcripts, so an
# offline machine or a dirty worktree must never be the reason this fails.

self_update() {
  [ -d "$ROOT/.git" ] || return 0
  command -v git >/dev/null 2>&1 || return 0
  git -C "$ROOT" pull --ff-only --quiet >/dev/null 2>&1 || true
}

logged_in() {
  "$PY_BIN" "$ROOT/bin/humalike_login.py" --status >/dev/null 2>&1
}

# --- the playbook ---------------------------------------------------------
# SOURCE OF TRUTH for the agent workflow. AGENTS.md and the Claude Code skill
# restate this; if you change the steps or the rules, change them there too.

print_playbook() {
  cat <<EOF
$RULE
   HUMALIKE SOCIAL AUDIT — playbook for the agent. Follow it in order.
$RULE

  An audit replays a real conversation and scores how the AI agent's
  messages actually landed with the human: a health score, the specific
  messages that damaged the interaction, and rewrites of the worst ones.

  SAY THIS TO THE HUMAN NOW:

    "Send me your transcript — a file path, or just paste it — and tell me
     which speaker is your agent. Then I'll run the audit."

  1. PREPARE. If they pasted text, write it to a file verbatim first — never
     clean, translate, trim, or reformat a transcript; that destroys the
     signal the audit reads. Costs credits. Starts nothing.

       python3 $AUDIT --json prepare --file <PATH>
       -> {"run_id": "...", "participants": [...], "agent_guess": "..."}

  2. ASK WHICH SPEAKER IS THE AGENT. Never guess silently. Show the
     participants, offer agent_guess as a default, and wait for a real
     answer — the wrong speaker does not give a slightly-off report, it
     gives a report about the wrong party.

  3. LAUNCH.

       python3 $AUDIT --json launch --run-id <ID> --agent "<CONFIRMED SPEAKER>"

  4. WAIT, then show the human the rendered report as it comes back.

       python3 $AUDIT wait --run-id <ID>

  RULES
    - Never invent a score, finding, or rewrite. Report only what the API
      returned; if a field is missing, say it is missing.
    - Rewrites are suggestions. Nothing was ever sent to anyone.
    - Always give the human the permalink: https://humalike.ai/audit?run=<ID>
    - Cap is 250 messages. If a transcript is over it, relay the server's
      error verbatim and OFFER the most recent 250. The human decides; you
      never trim silently.
    - Relay server errors verbatim — they carry exact counts and valid
      speaker names. 402 = out of credits, top up at https://humalike.ai.
      401/403 = the key is dead, run this script again.
    - Never print, echo, or ask for the API key or a password.

$RULE
EOF
}

print_login_block() {
  cat <<EOF

$RULE
   ACTION REQUIRED — SEND THIS LINK TO THE HUMAN NOW, VERBATIM.
$RULE
$(cat "$1")
  SAY THIS TO THE HUMAN NOW:

    "Click this link to log in — it creates your Humalike account too.
     Tell me once you've approved it."

  THEN run this. It blocks until they approve, then saves the key:

       bash $SHOW_ROOT/start --wait-login

  Nothing below works until that succeeds. Never print or ask for a key.

EOF
}

# --- modes ----------------------------------------------------------------

case "${1:-}" in
  --help | -h)
    usage
    exit 0
    ;;
  --status)
    check_prereqs
    if logged_in; then
      echo "Humalike audit CLI: ready (signed in, $SHOW_ROOT)."
      exit 0
    fi
    echo "Humalike audit CLI: not signed in. Run: bash $SHOW_ROOT/start"
    exit 1
    ;;
  --wait-login)
    check_prereqs
    if logged_in; then
      echo "  Already signed in. Nothing to wait for."
      exit 0
    fi
    echo "  Waiting for the human to approve the sign-in..."
    "$PY_BIN" "$ROOT/bin/humalike_login.py" --resume || exit 1
    echo
    print_playbook
    exit 0
    ;;
  "") ;;
  *)
    printf '\n  Unknown option: %s\n\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac

check_prereqs
self_update

if logged_in; then
  printf '\n  Signed in and ready — no login needed.\n\n'
  print_playbook
  exit 0
fi

# Not signed in. Get a link in the agent's hands without blocking it.
link_out="$(mktemp)"
trap 'rm -f "$link_out"' EXIT

if ! "$PY_BIN" "$ROOT/bin/humalike_login.py" --begin --no-browser >"$link_out" 2>&1; then
  printf '\n  Could not start the Humalike sign-in:\n\n' >&2
  sed 's/^/    /' "$link_out" >&2
  printf '\n  Check the network, then run: bash %s/start\n\n' "$SHOW_ROOT" >&2
  exit 1
fi

print_login_block "$link_out"
print_playbook
exit 0
